{
  "name": "hiring-ai-suite-backend",
  "version": "1.0.0",
  "description": "HIRING AI SUITE - B2B SaaS recruitment platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate --schema=src/database/prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:combined": "node dist/combined.js",
    "start:render": "prisma migrate deploy --schema=src/database/prisma/schema.prisma && node dist/combined.js",
    "worker": "tsx src/queues/workers.ts",
    "postinstall": "prisma generate --schema=src/database/prisma/schema.prisma || true",
    "prisma:generate": "prisma generate --schema=src/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/database/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/database/prisma/schema.prisma",
    "seed": "tsx src/database/prisma/seed.ts",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["hiring", "recruitment", "ai", "saas"],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "3.726.1",
    "@aws-sdk/s3-request-presigner": "3.726.1",
    "@prisma/client": "^6.1.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^7.5.0",
    "pdfkit": "^0.15.1",
    "helmet": "^8.0.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.8.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.13.8",
    "@types/node": "^22.10.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "jest": "^29.7.0",
    "prisma": "^6.1.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
