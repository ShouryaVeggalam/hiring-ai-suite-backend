NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=hiring-ai-suite
LOG_LEVEL=info
TRUST_PROXY=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hiring_ai_suite?schema=public
DATABASE_POOL_SIZE=10

REDIS_URL=redis://localhost:6379
REDIS_TLS=false

JWT_ACCESS_SECRET=change_me_access_min_16_chars
JWT_REFRESH_SECRET=change_me_refresh_min_16_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL=30m
BCRYPT_ROUNDS=12
JWT_REFRESH_COOKIE_NAME=refreshToken
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
APP_URL=http://localhost:4000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20

STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./uploads
VIRUS_SCAN_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hiring-ai-suite
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL=900
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

QUEUE_PREFIX=hiring-ai
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_MS=5000
WORKER_CONCURRENCY=5

AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Hiring AI Suite <no-reply@example.com>

WEBHOOK_SIGNING_SECRET=change_me_webhook_secret

METRICS_ENABLED=true
SWAGGER_ENABLED=true
REQUEST_TIMEOUT_MS=30000
